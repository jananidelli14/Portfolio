                    <img src="./images/clinical-report.png" alt="Clinical Decision Support System">
                    <div class="project-image-overlay">
                        <div class="image-expand-icon">ðŸ”</div>
                    </div>
                </div>
                <div class="project-content">
                    <span class="project-status live">In Production</span>
                    <h3 class="project-title">Clinical Decision Support</h3>
                    <p class="project-description">ML-powered system predicting geriatric polypharmacy risk with 85% accuracy. Delivers structured clinical recommendations with explainable decision factors.</p>
                    <div class="project-tags">
                        <span class="project-tag">Machine Learning</span>
                        <span class="project-tag">Healthcare</span>

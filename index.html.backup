                    <span class="tag">Machine Learning</span>
                    <span class="tag">Deep Learning</span>
                    <span class="tag">LLMs</span>
                    <span class="tag">Explainable AI</span>
                    <span class="tag">RAG</span>
                </div>
            </div>
            <div class="skill-group fade-in">

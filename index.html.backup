<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Janani D - AI Engineer & Product Builder</title>
    <style>
        :root {
            --bg-primary: #ffffff;
            --bg-secondary: #f5f9ff;
            --bg-tertiary: #eef4ff;
            --primary: #2563eb;
            --primary-light: #3b82f6;
            --primary-dark: #1e40af;
            --accent: #1e40af;
            --text-primary: #111111;
            --text-secondary: #4b5563;
            --text-muted: #9ca3af;
            --border: #d1dff0;
            --success: #10b981;
            --white: #ffffff;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            background: var(--bg-primary);
            color: var(--text-primary);
            font-family: 'Times New Roman', Times, serif;
            font-weight: 400;
            line-height: 1.6;
            overflow-x: hidden;
        }

        /* NAVIGATION */
        nav {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 500;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 56px;
            background: rgba(249, 248, 252, 0.95);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border);
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
        }

        .nav-logo {
            font-family: 'Times New Roman', Times, serif;
            font-weight: 800;
            font-size: 1.2rem;
            color: var(--primary);
            text-decoration: none;
            letter-spacing: -0.03em;
            transition: color 0.3s ease;
        }

        .nav-logo:hover {
            color: var(--primary-dark);
        }

        nav ul {
            display: flex;
            list-style: none;
            gap: 32px;
        }

        nav ul a {
            font-size: 0.95rem;
            font-weight: 500;
            color: var(--text-secondary);
            text-decoration: none;
            transition: color 0.3s ease;
            letter-spacing: -0.01em;
        }

        nav ul a:hover {
            color: var(--primary);
        }

        /* SECTIONS */
        section {
            position: relative;
            z-index: 1;
        }

        /* HERO */
        #hero {
            min-height: 100vh;
            padding: 120px 56px 80px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 60px;
            align-items: center;
            background: linear-gradient(135deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
            position: relative;
            overflow: hidden;
        }

        .hero-left {
            max-width: 600px;
            position: relative;
            z-index: 2;
        }

        .hero-tagline {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            font-size: 0.95rem;
            font-weight: 600;
            color: var(--primary);
            margin-bottom: 20px;
            padding: 8px 16px;
            background: rgba(37, 99, 235, 0.08);
            border-radius: 50px;
            border: 1px solid rgba(37, 99, 235, 0.2);
        }

        .hero-tagline::before {
            content: '';
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--primary);
            animation: pulse 2s ease-in-out infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.4; }
        }

        .hero-title {
            font-family: 'Times New Roman', Times, serif;
            font-size: clamp(2.4rem, 7vw, 4.2rem);
            font-weight: 800;
            line-height: 1.15;
            letter-spacing: -0.03em;
            margin-bottom: 20px;
            color: var(--text-primary);
        }

        .hero-title span {
            background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero-description {
            font-size: 1.05rem;
            line-height: 1.8;
            color: var(--text-secondary);
            margin-bottom: 32px;
            max-width: 550px;
        }

        .hero-buttons {
            display: flex;
            align-items: center;
            gap: 16px;
            flex-wrap: wrap;
            margin-bottom: 50px;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 12px 24px;
            font-size: 0.95rem;
            font-weight: 600;
            border-radius: 8px;
            text-decoration: none;
            transition: all 0.3s ease;
            cursor: pointer;
            border: none;
            font-family: 'Times New Roman', Times, serif;
            letter-spacing: -0.01em;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            color: white;
            box-shadow: 0 4px 16px rgba(37, 99, 235, 0.25);
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(37, 99, 235, 0.35);
        }

        .btn-secondary {
            background: var(--white);
            color: var(--text-primary);
            border: 2px solid var(--border);
        }

        .btn-secondary:hover {
            border-color: var(--primary);
            color: var(--primary);
            background: rgba(37, 99, 235, 0.04);
        }

        .btn-resume {
            background: var(--white);
            color: var(--primary);
            border: 2px solid var(--primary);
        }

        .btn-resume:hover {
            background: var(--primary);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(37, 99, 235, 0.3);
        }

        .hero-buttons {
            display: flex;
            gap: 16px;
            flex-wrap: wrap;
        }

        .btn-resume {
            background: var(--bg-primary);
            color: var(--primary);
            border: 2px solid var(--primary);
        }

        .btn-resume:hover {
            background: var(--primary);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(37, 99, 235, 0.3);
        }

        .hero-buttons {
            display: flex;
            gap: 16px;
            flex-wrap: wrap;
        }

        .hero-stats {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
        }

        .stat {
            display: flex;
            flex-direction: column;
            gap: 6px;
            padding: 20px;
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: 10px;
            transition: all 0.3s ease;
        }

        .stat:hover {
            box-shadow: 0 4px 12px rgba(37, 99, 235, 0.1);
            border-color: var(--primary);
        }

        .stat-value {
            font-size: 1.6rem;
            font-weight: 800;
            color: var(--primary);
            font-family: 'Times New Roman', Times, serif;
        }

        .stat-label {
            font-size: 0.8rem;
            color: var(--text-secondary);
            font-weight: 600;
            letter-spacing: 0.05em;
            text-transform: uppercase;
        }

        .hero-right {
            position: relative;
            z-index: 2;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .hero-image-wrap {
            width: 280px;
            height: 350px;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 20px 60px rgba(37, 99, 235, 0.15);
            border: 2px solid var(--border);
            background: var(--bg-secondary);
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 20px;
        }

        .hero-image-wrap img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: center;
            border-radius: 10px;
        }

        /* SECTION HEADER */
        .section {
            padding: 100px 56px;
        }

        .section-header {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-bottom: 60px;
        }

        .section-number {
            font-family: 'Times New Roman', Times, serif;
            font-size: 2.2rem;
            font-weight: 900;
            color: var(--primary);
            opacity: 0.2;
            line-height: 1;
            min-width: 60px;
        }

        .section-title {
            font-family: 'Times New Roman', Times, serif;
            font-size: clamp(1.6rem, 4vw, 2.6rem);
            font-weight: 800;
            color: var(--text-primary);
            letter-spacing: -0.02em;
        }

        .section-divider {
            flex: 1;
            height: 2px;
            background: linear-gradient(90deg, var(--border) 0%, transparent 100%);
        }

        /* ABOUT */
        #about {
            background: var(--bg-primary);
        }

        .about-grid {
            display: grid;
            grid-template-columns: 1.4fr 1fr;
            gap: 60px;
            align-items: start;
        }

        .about-text p {
            font-size: 1rem;
            line-height: 1.8;
            color: var(--text-secondary);
            margin-bottom: 18px;
        }

        .about-text strong {
            color: var(--text-primary);
            font-weight: 700;
        }

        .about-highlights {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .highlight-card {
            padding: 16px 18px;
            border-left: 3px solid var(--primary);
            background: rgba(37, 99, 235, 0.04);
            border-radius: 6px;
            transition: all 0.3s ease;
        }

        .highlight-card:hover {
            border-left-color: var(--accent);
            background: rgba(37, 99, 235, 0.08);
            transform: translateX(4px);
        }

        .highlight-label {
            font-size: 0.75rem;
            color: var(--primary);
            font-weight: 700;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            margin-bottom: 5px;
        }

        .highlight-text {
            font-size: 0.95rem;
            color: var(--text-primary);
            font-weight: 600;
        }

        /* SKILLS */
        #skills {
            background: var(--bg-secondary);
        }

        .skills-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
        }

        .skill-group {
            padding: 24px;
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: 12px;
            transition: all 0.3s ease;
        }

        .skill-group:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 32px rgba(37, 99, 235, 0.1);
            border-color: var(--primary);
        }

        .skill-group-title {
            font-size: 1rem;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 14px;
            letter-spacing: -0.01em;
        }

        .tags {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .tag {
            display: inline-block;
            padding: 6px 12px;
            background: rgba(37, 99, 235, 0.08);
            border: 1px solid var(--border);
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 500;
            color: var(--primary);
            transition: all 0.2s ease;
        }

        .tag:hover {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
            transform: scale(1.05);
        }

        /* PROJECTS */
        #projects {
            background: var(--bg-primary);
        }

        .projects-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 28px;
        }

        .project-card {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: 12px;
            overflow: hidden;
            transition: all 0.3s ease;
            display: flex;
            flex-direction: column;
            height: 100%;
        }

        .project-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 16px 48px rgba(37, 99, 235, 0.12);
            border-color: var(--primary);
        }

        .project-image-container {
            position: relative;
            height: 260px;
            background: linear-gradient(135deg, var(--bg-secondary) 0%, var(--bg-tertiary) 100%);
            overflow: hidden;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 20px;
        }

        .project-image-container img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            object-position: center;
            transition: transform 0.4s ease;
        }

        .project-image-placeholder {
            font-size: 2.5rem;
            font-weight: 800;
            color: white;
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .project-card:hover .project-image-container img {
            transform: scale(1.08);
        }

        .project-image-overlay {
            position: absolute;
            inset: 0;
            background: rgba(37, 99, 235, 0.75);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .project-image-container:hover .project-image-overlay {
            opacity: 1;
        }

        .image-expand-icon {
            font-size: 2.5rem;
            color: white;
        }

        .project-content {
            padding: 28px;
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .project-status {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            margin-bottom: 12px;
            padding: 6px 12px;
            background: rgba(37, 99, 235, 0.1);
            color: var(--primary);
            border-radius: 20px;
            width: fit-content;
        }

        .project-status.live {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
        }

        .project-status::before {
            content: '';
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: currentColor;
            animation: pulse 2s ease-in-out infinite;
        }

        .project-title {
            font-size: 1.2rem;
            font-weight: 800;
            color: var(--text-primary);
            margin-bottom: 12px;
            font-family: 'Times New Roman', Times, serif;
        }

        .project-description {
            font-size: 0.95rem;
            color: var(--text-secondary);
            line-height: 1.7;
            margin-bottom: 16px;
            flex-grow: 1;
        }

        .project-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-bottom: 20px;
        }

        .project-tag {
            display: inline-block;
            padding: 5px 11px;
            background: rgba(37, 99, 235, 0.08);
            border: 1px solid rgba(37, 99, 235, 0.15);
            border-radius: 6px;
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--primary);
        }

        .project-links {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .project-link {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 8px 16px;
            background: var(--primary);
            color: white;
            border: none;
            border-radius: 6px;
            font-size: 0.85rem;
            font-weight: 700;
            text-decoration: none;
            cursor: pointer;
            transition: all 0.3s ease;
            font-family: 'Times New Roman', Times, serif;
        }

        .project-link:hover {
            background: var(--primary-dark);
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);
        }

        .project-link-secondary {
            background: transparent;
            color: var(--primary);
            border: 2px solid var(--border);
            padding: 7px 14px;
        }

        .project-link-secondary:hover {
            border-color: var(--primary);
            background: rgba(37, 99, 235, 0.05);
        }

        /* MODAL */
        .modal {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.85);
            z-index: 1000;
            align-items: center;
            justify-content: center;
            padding: 20px;
            backdrop-filter: blur(4px);
            animation: fadeIn 0.3s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        .modal.active {
            display: flex;
        }

        .modal-content {
            background: var(--white);
            border-radius: 16px;
            max-width: 90vw;
            max-height: 90vh;
            overflow: auto;
            position: relative;
            animation: slideUp 0.3s ease;
        }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .modal-image {
            width: 100%;
            height: auto;
            display: block;
            border-radius: 16px;
        }

        .modal-close {
            position: absolute;
            top: 16px;
            right: 16px;
            width: 40px;
            height: 40px;
            background: rgba(0, 0, 0, 0.7);
            border: none;
            border-radius: 50%;
            color: white;
            font-size: 1.5rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
            z-index: 1001;
        }

        .modal-close:hover {
            background: rgba(0, 0, 0, 0.9);
            transform: scale(1.1);
        }

        /* EXPERIENCE */
        #experience {
            background: var(--bg-secondary);
        }

        .timeline {
            position: relative;
            max-width: 850px;
        }

        .timeline::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 2px;
            background: linear-gradient(180deg, var(--primary) 0%, transparent 100%);
        }

        .timeline-item {
            padding-left: 40px;
            padding-bottom: 45px;
            position: relative;
        }

        .timeline-item:last-child {
            padding-bottom: 0;
        }

        .timeline-item::before {
            content: '';
            position: absolute;
            left: -7px;
            top: 5px;
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: white;
            border: 3px solid var(--primary);
            box-shadow: 0 0 0 4px var(--bg-primary);
        }

        .timeline-date {
            font-size: 0.8rem;
            font-weight: 700;
            color: var(--primary);
            letter-spacing: 0.1em;
            text-transform: uppercase;
            margin-bottom: 6px;
        }

        .timeline-title {
            font-size: 1.15rem;
            font-weight: 800;
            color: var(--text-primary);
            margin-bottom: 4px;
            font-family: 'Times New Roman', Times, serif;
        }

        .timeline-company {
            font-size: 0.95rem;
            color: var(--text-secondary);
            margin-bottom: 10px;
            font-weight: 600;
        }

        .timeline-description {
            font-size: 0.95rem;
            color: var(--text-secondary);
            line-height: 1.7;
            margin-bottom: 14px;
        }

        .timeline-points {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .timeline-points li {
            font-size: 0.9rem;
            color: var(--text-secondary);
            padding-left: 20px;
            position: relative;
            line-height: 1.65;
        }

        .timeline-points li::before {
            content: 'â–¸';
            position: absolute;
            left: 4px;
            color: var(--primary);
            font-weight: 700;
        }

        /* HACKATHONS */
        #hackathons {
            background: var(--bg-primary);
        }

        .hackathons-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 24px;
        }

        .hackathon-card {
            padding: 26px;
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: 12px;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .hackathon-card::before {
            content: 'â—†';
            position: absolute;
            top: -15px;
            right: -5px;
            font-size: 3.5rem;
            color: rgba(37, 99, 235, 0.06);
            pointer-events: none;
        }

        .hackathon-card:hover {
            transform: translateY(-4px);
            border-color: var(--primary);
            box-shadow: 0 12px 32px rgba(37, 99, 235, 0.1);
        }

        .hackathon-year {
            font-size: 0.75rem;
            font-weight: 700;
            color: var(--primary);
            letter-spacing: 0.1em;
            text-transform: uppercase;
            margin-bottom: 8px;
        }

        .hackathon-name {
            font-size: 1.05rem;
            font-weight: 800;
            color: var(--text-primary);
            margin-bottom: 12px;
            font-family: 'Times New Roman', Times, serif;
        }

        .hackathon-description {
            font-size: 0.9rem;
            color: var(--text-secondary);
            line-height: 1.7;
            margin-bottom: 14px;
        }

        .hackathon-achievement {
            display: inline-block;
            margin-top: 12px;
            padding: 6px 12px;
            background: rgba(37, 99, 235, 0.1);
            color: var(--primary);
            font-size: 0.75rem;
            font-weight: 700;
            border-radius: 6px;
            letter-spacing: 0.05em;
        }

        .hackathon-achievement.winning {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
        }

        /* CERTIFICATIONS */
        #certifications {
            background: var(--bg-secondary);
        }

        .certs-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 16px;
        }

        .cert-card {
            display: flex;
            align-items: flex-start;
            gap: 16px;
            padding: 20px;
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: 10px;
            transition: all 0.3s ease;
        }

        .cert-card:hover {
            box-shadow: 0 8px 20px rgba(37, 99, 235, 0.1);
            border-color: var(--primary);
            transform: translateY(-2px);
        }

        .cert-icon {
            width: 48px;
            height: 48px;
            border-radius: 8px;
            background: rgba(37, 99, 235, 0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
            flex-shrink: 0;
        }

        .cert-info h4 {
            font-size: 0.9rem;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 4px;
            line-height: 1.4;
        }

        .cert-info p {
            font-size: 0.8rem;
            color: var(--text-secondary);
            margin: 0;
        }

        /* CONTACT FORM */
        #contact {
            background: linear-gradient(135deg, #1a1f35 0%, #0f1419 100%);
            padding: 100px 56px;
            color: #ffffff;
        }

        .contact-header {
            text-align: center;
            margin-bottom: 50px;
        }

        .contact-tagline {
            font-size: 0.9rem;
            font-weight: 600;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: var(--primary);
            margin-bottom: 14px;
        }

        .contact-title {
            font-family: 'Times New Roman', Times, serif;
            font-size: clamp(1.8rem, 4vw, 2.6rem);
            font-weight: 800;
            margin-bottom: 14px;
            line-height: 1.2;
            letter-spacing: -0.02em;
            color: var(--text-primary);
        }

        .contact-description {
            font-size: 1rem;
            color: var(--text-secondary);
            max-width: 500px;
            margin: 0 auto;
            line-height: 1.7;
        }

        .contact-form-container {
            max-width: 900px;
            margin: 50px auto;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 50px;
            padding: 40px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 16px;
            backdrop-filter: blur(25px);
        }

        .form-group {
            margin-bottom: 24px;
        }

        .form-label {
            display: block;
            font-size: 0.8rem;
            font-weight: 700;
            color: #7a8299;
            margin-bottom: 10px;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }

        .form-input,
        .form-textarea {
            width: 100%;
            padding: 12px 16px;
            background: rgba(31, 41, 81, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 8px;
            color: #ffffff;
            font-family: 'Times New Roman', Times, serif;
            font-size: 0.95rem;
            outline: none;
            transition: all 0.3s ease;
        }

        .form-input::placeholder,
        .form-textarea::placeholder {
            color: #7a8299;
        }

        .form-input:focus,
        .form-textarea:focus {
            border-color: #00d4ff;
            background: rgba(31, 41, 81, 0.8);
            box-shadow: 0 0 0 3px rgba(0, 212, 255, 0.1);
        }

        .form-textarea {
            resize: vertical;
            min-height: 120px;
            font-family: 'Times New Roman', Times, serif;
        }

        .form-submit {
            width: 100%;
            padding: 12px 24px;
            background: linear-gradient(135deg, #00d4ff 0%, #0099dd 100%);
            color: #000;
            border: none;
            border-radius: 8px;
            font-size: 0.95rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
            font-family: 'Times New Roman', Times, serif;
        }

        .form-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0, 212, 255, 0.4);
        }

        .form-submit:active {
            transform: translateY(0);
        }

        .form-success {
            display: none;
            padding: 14px 16px;
            background: rgba(16, 185, 129, 0.1);
            border: 1px solid rgba(16, 185, 129, 0.3);
            color: var(--success);
            border-radius: 8px;
            margin-bottom: 20px;
            font-weight: 600;
            text-align: center;
        }

        .form-success.show {
            display: block;
            animation: slideUp 0.3s ease;
        }

        .contact-links-section {
            text-align: center;
            margin-top: 60px;
            padding-top: 40px;
            border-top: 1px solid var(--border);
        }

        .contact-links-title {
            font-size: 0.9rem;
            font-weight: 600;
            color: var(--text-secondary);
            letter-spacing: 0.1em;
            text-transform: uppercase;
            margin-bottom: 20px;
        }

        .contact-links {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 24px;
            flex-wrap: wrap;
        }

        .contact-link {
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--text-primary);
            text-decoration: none;
            font-weight: 600;
            font-size: 0.95rem;
            transition: all 0.3s ease;
            letter-spacing: -0.01em;
        }

        .contact-link:hover {
            color: var(--primary);
            transform: translateY(-2px);
        }

        .contact-link-icon {
            font-size: 1.2rem;
        }

        .contact-info-sidebar {
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .contact-info {
            display: flex;
            align-items: flex-start;
            gap: 16px;
            margin-bottom: 24px;
        }

        .contact-info-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            background: rgba(0, 212, 255, 0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
            flex-shrink: 0;
        }

        .contact-info-text {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .contact-info-label {
            font-size: 0.75rem;
            font-weight: 700;
            color: #7a8299;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }

        .contact-info-value {
            font-size: 0.95rem;
            font-weight: 600;
            color: #ffffff;
        }

        .contact-social {
            display: flex;
            gap: 12px;
            margin-top: 24px;
            padding-top: 24px;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
        }

        .contact-social-link {
            width: 40px;
            height: 40px;
            border-radius: 8px;
            background: rgba(0, 212, 255, 0.1);
            border: 1px solid rgba(0, 212, 255, 0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            transition: all 0.3s ease;
            text-decoration: none;
            color: #00d4ff;
        }

        .contact-social-link:hover {
            background: #00d4ff;
            color: #000;
            box-shadow: 0 4px 12px rgba(0, 212, 255, 0.3);
        }

        .availability-banner {
            padding: 16px;
            background: rgba(0, 212, 255, 0.1);
            border: 1px solid rgba(0, 212, 255, 0.3);
            border-radius: 8px;
            text-align: center;
            color: #00d4ff;
            font-weight: 600;
            cursor: default;
            margin-top: 24px;
        }

        /* FOOTER */
        footer {
            background: var(--text-primary);
            color: var(--white);
            padding: 32px 56px;
            text-align: center;
            border-top: 1px solid var(--border);
        }

        footer p {
            font-size: 0.85rem;
            margin: 0;
            opacity: 0.9;
        }

        /* ANIMATIONS */
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .fade-in {
            opacity: 0;
            animation: fadeInUp 0.6s ease both;
        }

        .fade-in:nth-child(1) { animation-delay: 0.1s; }
        .fade-in:nth-child(2) { animation-delay: 0.2s; }
        .fade-in:nth-child(3) { animation-delay: 0.3s; }
        .fade-in:nth-child(4) { animation-delay: 0.4s; }

        /* RESPONSIVE */
        @media (max-width: 1024px) {
            nav {
                padding: 14px 32px;
            }

            nav ul {
                gap: 24px;
            }

            nav ul a {
                font-size: 0.9rem;
            }

            #hero {
                grid-template-columns: 1fr;
                padding: 100px 32px 60px;
                gap: 40px;
            }

            .hero-right {
                display: none;
            }

            .section {
                padding: 80px 32px;
            }

            .about-grid {
                grid-template-columns: 1fr;
            }

            .projects-grid {
                grid-template-columns: 1fr;
            }

            .skills-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .hero-stats {
                grid-template-columns: repeat(2, 1fr);
            }

            .contact-form-container {


                padding: 24px;
                grid-template-columns: 1fr;
                gap: 30px;
            }
        }

        @media (max-width: 768px) {
            nav {
                padding: 12px 20px;
            }

            nav ul {
                gap: 16px;
            }

            nav ul a {
                font-size: 0.8rem;
            }

            #hero {
                padding: 80px 20px 50px;
                gap: 30px;
            }

            .hero-title {
                font-size: 1.8rem;
            }

            .hero-buttons {
                flex-direction: column;
                width: 100%;
            }

            .btn {
                width: 100%;
                justify-content: center;
            }

            section {
                padding: 60px 20px;
            }

            .section-header {
                flex-wrap: wrap;
                gap: 12px;
            }

            .section-title {
                font-size: 1.4rem;
            }

            .section-divider {
                flex: 1 1 100%;
            }

            .about-grid {
                gap: 32px;
            }

            .projects-grid,
            .hackathons-grid,
            .certs-grid {
                grid-template-columns: 1fr;
            }

            .skills-grid {
                grid-template-columns: 1fr;
            }

            .hero-stats {
                grid-template-columns: repeat(2, 1fr);
                gap: 14px;
            }

            .timeline::before {
                left: -16px;
            }

            .timeline-item {
                padding-left: 24px;
            }

            .timeline-item::before {
                left: -24px;
            }

            #contact {
                padding: 70px 20px;
            }

            .contact-title {
                font-size: 1.6rem;
            }

            .contact-form-container {
                margin: 30px auto;
                padding: 20px;
            }

            footer {
                padding: 24px;
            }
        }

        @media (max-width: 480px) {
            nav {
                padding: 12px 16px;
            }

            .nav-logo {
                font-size: 1rem;
            }

            nav ul {
                gap: 12px;
            }

            nav ul a {
                font-size: 0.7rem;
                font-weight: 600;
            }

            #hero {
                padding: 70px 16px 50px;
                gap: 20px;
            }

            .hero-title {
                font-size: 1.5rem;
                margin-bottom: 14px;
            }

            .hero-description {
                font-size: 0.95rem;
                margin-bottom: 24px;
            }

            .section-title {
                font-size: 1.2rem;
            }

            .hero-stats {
                grid-template-columns: 1fr;
                gap: 12px;
            }

            section {
                padding: 50px 16px;
            }

            .projects-grid {
                grid-template-columns: 1fr;
            }

            .project-card {
                margin: 0;
            }

            .modal-close {
                width: 36px;
                height: 36px;
                font-size: 1.3rem;
            }

            .contact-links {
                gap: 14px;
                flex-direction: column;
            }

            .contact-link {
                flex-direction: column;
                gap: 4px;
                font-size: 0.85rem;
            }
        }
    </style>
</head>
<body>
    <!-- NAVIGATION -->
    <nav>
        <a href="#hero" class="nav-logo">Janani D</a>
        <ul>
            <li><a href="#about">About</a></li>
            <li><a href="#skills">Skills</a></li>
            <li><a href="#projects">Projects</a></li>
            <li><a href="#experience">Experience</a></li>

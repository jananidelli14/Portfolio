            <li><a href="#contact">Contact</a></li>
        </ul>
    </nav>

    <!-- HERO -->
    <section id="hero">
        <div class="hero-left">
            <div class="hero-tagline">Available for opportunities</div>
            <h1 class="hero-title">Building <span>intelligent systems</span> that solve real problems</h1>
            <p class="hero-description">AI Engineer & Product Builder. Turning complex data and ML into products that work in the real world â€” from clinical decision support systems to AI-powered mobile apps.</p>
            <div class="hero-buttons">
                <a href="#projects" class="btn btn-primary">Explore Projects</a>
                <a href="#contact" class="btn btn-secondary">Get in Touch</a>
                <a href="./resume.pdf" class="btn btn-resume" download>ðŸ“„ Download Resume</a>
            </div>
            <div class="hero-stats">
                <div class="stat fade-in">
                    <div class="stat-value">85%</div>
                    <div class="stat-label">ML Accuracy</div>
                </div>
                <div class="stat fade-in">
                    <div class="stat-value">3</div>
                    <div class="stat-label">Live Products</div>
                </div>
                <div class="stat fade-in">
                    <div class="stat-value">2</div>
                    <div class="stat-label">Hackathons 2026</div>
                </div>
                <div class="stat fade-in">
                    <div class="stat-value">5+</div>
                    <div class="stat-label">Certifications</div>
                </div>
            </div>
        </div>
        <div class="hero-right">
            <div class="hero-image-wrap">
                <img src="./images/profile.jpg" alt="Janani D" title="Janani D">
            </div>
        </div>
    </section>

    <!-- ABOUT -->
    <section id="about" class="section">
        <div class="section-header">
            <div class="section-number">01</div>
            <h2 class="section-title">About</h2>
            <div class="section-divider"></div>
        </div>
        <div class="about-grid fade-in">
            <div class="about-text">
                <p>I'm an <strong>AI & Data Science student</strong> at Rajalakshmi Institute of Technology, but I think like an engineer shipping products. I don't just learn concepts â€” I <strong>build systems that work at scale</strong>.</p>
                <p>From developing <strong>clinical decision support systems</strong> that use ML to predict drug-disease risk, to building <strong>real-time AI safety apps</strong> for women travelers, I focus on outcomes that matter. I'm comfortable going deep on machine learning, data pipelines, and explainable AI â€” but I'm equally excited about shipping clean, production-ready code.</p>
                <p>Currently competing in <strong>two simultaneous hackathons</strong>, balancing a data science internship with leadership roles in student initiatives. I thrive under pressure and love translating research into reality.</p>
                <p>Outside of tech, I'm a <strong>JLPT N5 certified Japanese speaker</strong> â€” a language I picked up out of pure curiosity, which says a lot about how I approach learning new things.</p>
            </div>
            <div class="about-highlights">
                <div class="highlight-card fade-in">
                    <div class="highlight-label">Mindset</div>
                    <div class="highlight-text">Builder, not learner</div>
                </div>
                <div class="highlight-card fade-in">
                    <div class="highlight-label">Focus</div>
                    <div class="highlight-text">Impact-driven engineering</div>
                </div>
                <div class="highlight-card fade-in">
                    <div class="highlight-label">Stack</div>
                    <div class="highlight-text">ML, Python, Real-time Systems</div>
                </div>
                <div class="highlight-card fade-in">
                    <div class="highlight-label">Best at</div>
                    <div class="highlight-text">End-to-end AI, dashboards, explainable ML</div>
                </div>
            </div>
        </div>
    </section>

    <!-- SKILLS -->
